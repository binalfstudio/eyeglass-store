# Core server settings
PORT=5000
NODE_ENV=development
JWT_SECRET=replace_with_random_string_at_least_32_characters_long
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5174
SERVER_URL=http://localhost:5000

# MySQL settings
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=eyeglass_db

# Admin account creation (required secret for admin registration)
ADMIN_REGISTRATION_KEY=replace_with_a_private_admin_key

# Chapa payment gateway
CHAPA_SECRET_KEY=
CHAPA_API_BASE_URL=https://api.chapa.co/v1
CHAPA_RETURN_URL=http://localhost:5174/payment-result
CHAPA_CALLBACK_URL=http://localhost:5000/api/payments/webhook/chapa
CHAPA_WEBHOOK_SECRET=replace_with_random_webhook_secret
CHAPA_TEST_PHONE_NUMBER=

# Gemini AI image generation
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Optional SMS (Africa's Talking)
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=
